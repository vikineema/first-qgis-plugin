# ####################################################################
# JUPYER Env variables
# Majority of the jupyter lab config is in the  file:
# ./jupyter_lab_config.py
# #####################################################################
JUPYTER_PORT=9991
## QGIS
CONDA_ENV_NAME=qgis-plugin-dev
CONDA_ENV_PATH=$(MAMBA_ROOT_PREFIX)/envs/$(CONDA_ENV_NAME)
QGIS_PATH=$(CONDA_ENV_PATH)/bin/qgis
QGIS_PROFILES_DIR=$(HOME)/.local/share/QGIS/QGIS3/profiles
QGIS_PROFILE_NAME=BASEMAP_PLUGIN
QGIS_PROFILE_PATH=$(QGIS_PROFILES_DIR)/$(QGIS_PROFILE_NAME)
